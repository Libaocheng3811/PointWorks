   </attribute>
   <widget class="QWidget" name="PropertiesTable">
    <layout class="QVBoxLayout" name="verticalLayout_3">
     <item>
      <widget class="QTableWidget" name="cloudtable">
       <property name="styleSheet">
        <string notr="true">QTableWidget{
	border: 1px solid #C0C4C8;
	outline: 0px;
	border-radius: 4px;
	background: #FFFFFF;
	alternate-background-color: #F5F7FA;
}
QTableWidget::item {
	padding: 2px 4px;
}
QTableWidget::item:selected {
	background-color: #EAF0F8;
	color: #19232D;
}
/* SpinBox 美化 */
QTableWidget QSpinBox,
QTableWidget QDoubleSpinBox {
	border: 1px solid #D0D4D8;
	border-radius: 3px;
	padding: 1px 4px;
	background: transparent;
	min-width: 60px;
}
QTableWidget QSpinBox::up-button,
QTableWidget QDoubleSpinBox::up-button {
	border: none;
	width: 16px;
}
QTableWidget QSpinBox::down-button,
QTableWidget QDoubleSpinBox::down-button {
	border: none;
	width: 16px;
}
QTableWidget QSpinBox::up-arrow,
QTableWidget QDoubleSpinBox::up-arrow,
QTableWidget QSpinBox::down-arrow,
QTableWidget QDoubleSpinBox::down-arrow {
	width: 8px;
	height: 8px;
}
/* ComboBox 美化 */
QTableWidget QComboBox {
	border: 1px solid #D0D4D8;
	border-radius: 3px;
	padding: 1px 4px;
	background: transparent;
	min-width: 60px;
}
/* 垂直滚动条 */
QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #a6a6a6;
    border-radius: 4px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #888888;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

/* 水平滚动条 */
QScrollBar:horizontal {
    background: transparent;
    height: 8px;
    margin: 0px;
}

QScrollBar::handle:horizontal {
    background: #a6a6a6;
    border-radius: 4px;
    min-width: 20px;
}

QScrollBar::handle:horizontal:hover {
    background: #888888;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}
</string>
       </property>
       <property name="verticalScrollBarPolicy">
