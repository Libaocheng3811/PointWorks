       <property name="styleSheet">
        <string notr="true">QTreeWidget{
	border: 2px solid lightgray;
	outline: 0px; 
	border-radius: 8px;
	background: white;
}

QTreeWidget::item {
    padding: 5px;
}

QHeaderView::section {
    background-color: #e0e0e0;
    color: #222;
    padding: 2px;
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    border: none;                   /* 去掉边框 */
}

QHeaderView {
    border: none;
    background: transparent;
}
</string>
