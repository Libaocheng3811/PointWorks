<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="100%" height="100%">
    <defs>
        <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#1A1C29" />
            <stop offset="100%" stop-color="#090A0F" />
        </linearGradient>

        <linearGradient id="pwGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00E5FF" />
            <stop offset="60%" stop-color="#007BFF" />
            <stop offset="100%" stop-color="#5E35B1" />
        </linearGradient>

        <linearGradient id="accentGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#FF6D00" />
            <stop offset="100%" stop-color="#FF3D00" />
        </linearGradient>

        <linearGradient id="meshFill" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00E5FF" stop-opacity="0.12" />
            <stop offset="100%" stop-color="#007BFF" stop-opacity="0.03" />
        </linearGradient>

        <filter id="glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="12" result="blur" />
            <feComposite in="SourceGraphic" in2="blur" operator="over" />
        </filter>
    </defs>

    <rect width="512" height="512" rx="112" fill="url(#bgGradient)" />

    <g fill="#00E5FF" opacity="0.4">
        <circle cx="85" cy="115" r="3" />
        <circle cx="120" cy="80" r="4" />
        <circle cx="390" cy="90" r="2" />
        <circle cx="450" cy="140" r="5" />
        <circle cx="475" cy="290" r="3" />
        <circle cx="430" cy="410" r="4" />
        <circle cx="360" cy="460" r="2" />
        <circle cx="180" cy="450" r="4" />
        <circle cx="100" cy="390" r="3" />
    </g>

    <g fill="#007BFF" opacity="0.3">
        <circle cx="240" cy="85" r="4" />
        <circle cx="310" cy="110" r="3" />
        <circle cx="450" cy="350" r="4" />
        <circle cx="110" cy="230" r="2" />
        <circle cx="280" cy="440" r="3" />
    </g>

    <g stroke="#00E5FF" stroke-width="1.5" stroke-opacity="0.25" fill="url(#meshFill)">
        <polygon points="140,280 230,260 270,360" />
        <polygon points="230,260 320,240 270,360" />
        <polygon points="320,240 370,360 420,160" />
        <polygon points="140,160 230,260 140,280" opacity="0.4"/>
    </g>

    <g fill="none" stroke="url(#pwGradient)" stroke-width="26" stroke-linecap="round" stroke-linejoin="round" filter="url(#glow)">
        <path d="M 140,360 L 140,160 A 60,60 0 1,1 140,280" />
        
        <path d="M 230,260 L 270,360 L 320,240 L 370,360 L 420,160" />
    </g>

    <g>
        <circle cx="140" cy="360" r="16" fill="url(#pwGradient)" />
        <circle cx="140" cy="160" r="16" fill="url(#pwGradient)" />
        <circle cx="140" cy="280" r="16" fill="url(#pwGradient)" />
        <circle cx="200" cy="220" r="16" fill="url(#pwGradient)" /> <circle cx="230" cy="260" r="16" fill="url(#pwGradient)" />
        <circle cx="270" cy="360" r="16" fill="url(#pwGradient)" />
        
        <circle cx="320" cy="240" r="22" fill="url(#accentGradient)" filter="url(#glow)" /> 
        
        <circle cx="370" cy="360" r="16" fill="url(#pwGradient)" />
        <circle cx="420" cy="160" r="16" fill="url(#pwGradient)" />
    </g>

    <g fill="#FFFFFF" opacity="0.6">
        <circle cx="136" cy="156" r="4" />
        <circle cx="136" cy="276" r="4" />
        <circle cx="136" cy="356" r="4" />
        <circle cx="196" cy="216" r="4" />
        <circle cx="226" cy="256" r="4" />
        <circle cx="266" cy="356" r="4" />
        <circle cx="366" cy="356" r="4" />
        <circle cx="416" cy="156" r="4" />
        <circle cx="316" cy="236" r="6" /> </g>
</svg>
